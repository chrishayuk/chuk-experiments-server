# Postgres connection string (Neon in production, local Postgres in dev)
DATABASE_URL=postgresql://experiments:experiments@localhost:5433/experiments

# Comma-separated bootstrap API key for local dev: name:scope1|scope2:rawkey
# In production, keys are created via `chuk-experiments-server keys create` and
# only the sha256 hash is stored.
EXPERIMENTS_BOOTSTRAP_KEY=chris-cli:read|write|admin:dev-local-key

MCP_LOG_LEVEL=INFO

# Cloudflare R2 (Phase 2 artifacts) — optional. Without these set, the
# /artifacts/presign and /artifacts/{id}/download routes reply 501
# not_implemented rather than erroring; everything else works fine.
# Own dedicated bucket ("chuk-experiments"), separate from
# gpu-training-harness's "chuk-train" bucket — create an R2 API token scoped
# to just this bucket (Cloudflare dashboard -> R2 -> Manage R2 API Tokens).
R2_BUCKET=chuk-experiments
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Dashboard (Phase 4) — optional. Without these set, /login replies 503
# "sign-in is not configured" rather than erroring; the REST API and MCP
# tools are unaffected either way.
#
# Reuses chuk-mcp-stage's existing Google OAuth client rather than minting a
# new one — get the Client ID/Secret from that project, and add this
# deployment's callback URL (http://localhost:8000/auth/callback locally,
# https://chuk-experiments-server.fly.dev/auth/callback in prod) to that
# OAuth client's authorized redirect URIs in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
DASHBOARD_ALLOWED_EMAIL=chrishayuk@googlemail.com

# Signs the dashboard's session cookie (HMAC-SHA256) — any long random
# string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SESSION_SECRET=

# Unused by any code path since the dashboard was rewritten as a client-side
# SPA — the browser calls /v1/* directly via its own Google session cookie,
# no server-side proxy to authenticate. Safe to leave unset; kept only for
# backward compatibility with existing Fly secrets/test fixtures.
INTERNAL_API_KEY=

# Google Drive artifact storage — backs POST /runs/{id}/artifacts/upload
# (small provenance/config/log/dataset files an agent has bytes for right
# now) and the one-off scripts/archive_*_to_drive.py migration scripts.
# Without these set, the upload route replies 501 not_implemented; everything
# else works fine. Reuses gpu-training-harness's existing OAuth client +
# refresh token (drive.file scope: the app can only see/manage files it
# created itself) rather than registering a new one — copy the
# CHUK_TRAIN_GOOGLE_* values from that project's .env, or mint a fresh
# refresh token with its scripts/authorize-drive.py.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# External artifact reference verification (external_refs.py) — optional,
# server-wide fallback only. verify_artifact prefers the requesting user's
# own token (Team screen, encrypted with TOKEN_ENCRYPTION_KEY below) and
# only falls back to these for bootstrap/CI keys with no owning user, or
# users who haven't set a personal one yet. Unauthenticated GitHub API
# access is 60 req/hr; a personal access token (no scopes needed) bumps it
# to 5000/hr. Hugging Face's public repo tree API needs no auth at all for
# public repos — HUGGINGFACE_TOKEN is only for verifying private ones.
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=

# Encrypts app_user.github_token_encrypted/huggingface_token_encrypted at
# rest (Fernet) — without this set, saving a personal token from the Team
# screen fails with a clear "not configured" error rather than storing
# anything insecurely. Generate with:
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
TOKEN_ENCRYPTION_KEY=
