# Postgres connection string (Neon in production, local Postgres in dev)
DATABASE_URL=postgresql://experiments:experiments@localhost:5433/experiments

# Comma-separated bootstrap API key for local dev: name:scope1|scope2:rawkey
# In production, keys are created via `chuk-experiments-server keys create` and
# only the sha256 hash is stored.
EXPERIMENTS_BOOTSTRAP_KEY=chris-cli:read|write|admin:dev-local-key

MCP_LOG_LEVEL=INFO
